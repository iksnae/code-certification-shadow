+// Package language_tiers classifies programming languages into certification tiers
+// based on analyzer support. TierFull languages have full structural analysis;
+// all others fall back to TierGeneric.
+package language_tiers
+
+import "github.com/iksnae/code-certification/internal/analysis"
+
+// Tier represents the analysis capability level for a language.
+type Tier int
+
+const (
+	// TierGeneric is the default tier for languages without dedicated analysis support.
+	TierGeneric Tier = iota
+	// TierFull is the tier for languages with full structural analysis support.
+	TierFull
+)
+
+// TierForLanguage returns the analysis tier for the given language identifier.
+// Languages registered with a dedicated analyzer return TierFull; all others
+// return TierGeneric.
+func TierForLanguage(lang string) Tier {
+	if analysis.ForLanguage(lang) != nil {
+		return TierFull
+	}
+	return TierGeneric
+}
