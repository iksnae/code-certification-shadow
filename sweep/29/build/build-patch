+package language_tiers
+
+import "github.com/iksnae/code-certification/internal/analysis"
+
+// Tier classifies a language's tooling support level.
+type Tier int
+
+const (
+	// TierGeneric means the language is not specifically supported —
+	// only generic, parser-agnostic checks apply.
+	TierGeneric Tier = iota
+
+	// TierFull means the language has full parser support and rich analysis.
+	TierFull
+)
+
+// TierForLanguage returns the support tier for the given language identifier.
+func TierForLanguage(lang string) Tier {
+	a := analysis.ForLanguage(lang)
+	if a != nil {
+		return TierFull
+	}
+	return TierGeneric
+}
