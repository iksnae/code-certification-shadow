+++ b/internal/language_tiers/language_tiers_test.go
@@ -0,0 +1,37 @@
+package language_tiers_test
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/language_tiers"
+)
+
+func TestTierForLanguage(t *testing.T) {
+	tests := []struct {
+		name string
+		lang string
+		want language_tiers.Tier
+	}{
+		// Registered languages → TierFull
+		{name: "go", lang: "go", want: language_tiers.TierFull},
+		{name: "ts", lang: "ts", want: language_tiers.TierFull},
+		{name: "py", lang: "py", want: language_tiers.TierFull},
+		{name: "rs", lang: "rs", want: language_tiers.TierFull},
+		{name: "js", lang: "js", want: language_tiers.TierFull},
+
+		// Unregistered / unknown languages → TierGeneric
+		{name: "ruby", lang: "ruby", want: language_tiers.TierGeneric},
+		{name: "swift", lang: "swift", want: language_tiers.TierGeneric},
+		{name: "c", lang: "c", want: language_tiers.TierGeneric},
+		{name: "empty string", lang: "", want: language_tiers.TierGeneric},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got := language_tiers.TierForLanguage(tt.lang)
+			if got != tt.want {
+				t.Errorf("TierForLanguage(%q) = %v, want %v", tt.lang, got, tt.want)
+			}
+		})
+	}
+}
