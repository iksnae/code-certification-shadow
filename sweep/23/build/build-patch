+// TierForLanguage returns the analysis tier for a language identifier.
+// Known languages return their registered tier; unrecognized languages return TierGeneric.
+func TierForLanguage(lang string) Tier {
+	if tier, ok := languageTiers[strings.ToLower(strings.TrimSpace(lang))]; ok {
+		return tier
+	}
+	return TierGeneric
+}
diff --git a/internal/engine/language_tiers_test.go b/internal/engine/language_tiers_test.go
