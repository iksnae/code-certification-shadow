+func TestKnownLanguages(t *testing.T) {
+	langs := discovery.KnownLanguages()
+
+	// Every extension in certifiableExts should map to a language returned by KnownLanguages
+	langSet := make(map[string]bool, len(langs))
+	for _, l := range langs {
+		langSet[l] = true
+	}
+
+	// Verify all language IDs from certifiableExts are present
+	// These are the unique language IDs extracted manually from certifiableExts:
+	expected := map[string]bool{
+		"go": true, "ts": true, "js": true, "py": true, "rb": true,
+		"rs": true, "java": true, "kt": true, "sh": true, "c": true,
+		"cpp": true, "cs": true, "swift": true, "php": true, "elixir": true,
+		"erlang": true, "scala": true, "lua": true, "r": true, "zig": true,
+		"sql": true, "proto": true,
+	}
+
+	for lang := range expected {
+		if !langSet[lang] {
+			t.Errorf("KnownLanguages() missing language %q that exists in certifiableExts", lang)
+		}
+	}
+
+	for lang := range langSet {
+		if !expected[lang] {
+			t.Errorf("KnownLanguages() returned unexpected language %q not in certifiableExts", lang)
+		}
+	}
+
+	// Should be sorted
+	for i := 1; i < len(langs); i++ {
+		if langs[i-1] >= langs[i] {
+			t.Errorf("KnownLanguages() not sorted: %q >= %q at index %d", langs[i-1], langs[i], i)
+		}
+	}
+
+	// Must not be empty
+	if len(langs) == 0 {
+		t.Error("KnownLanguages() returned empty slice")
+	}
+}
