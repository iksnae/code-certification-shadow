+package engine_test
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+	"github.com/iksnae/code-certification/internal/engine"
+)
+
+// TestTierRegistry_AllKnownLanguagesHaveTiers ensures every language ID returned
+// by discovery.KnownLanguages() has a non-None tier entry in the engine registry.
+// This fails CI when a new extension is added to certifiableExts without a
+// corresponding tier entry.
+func TestTierRegistry_AllKnownLanguagesHaveTiers(t *testing.T) {
+	langs := discovery.KnownLanguages()
+	for _, lang := range langs {
+		tier := engine.TierForLanguage(lang)
+		if tier == engine.TierNone {
+			t.Errorf("discovery.KnownLanguages() includes %q but engine.TierForLanguage(%q) returns TierNone — add a tier entry in languageTiers", lang, lang)
+		}
+	}
+}
+
+// TestTierRegistry_UnknownLanguageReturnsGeneric asserts that an unrecognized
+// language ID falls back to TierGeneric.
+func TestTierRegistry_UnknownLanguageReturnsGeneric(t *testing.T) {
+	got := engine.TierForLanguage("nonsense-language")
+	if got != engine.TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s", "nonsense-language", got, engine.TierGeneric)
+	}
+}
+
+// TestTierRegistry_SwiftIsGeneric is a regression pin: Swift must remain at
+// TierGeneric until tree-sitter parsing is implemented.
+func TestTierRegistry_SwiftIsGeneric(t *testing.T) {
+	got := engine.TierForLanguage("swift")
+	if got != engine.TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s — Swift must stay at TierGeneric", "swift", got, engine.TierGeneric)
+	}
+}
