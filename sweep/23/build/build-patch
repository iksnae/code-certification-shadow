+// KnownLanguages returns a deduplicated, sorted slice of every language ID
+// that appears in certifiableExts.
+func KnownLanguages() []string {
+	set := make(map[string]bool)
+	for _, lang := range certifiableExts {
+		set[lang] = true
+	}
+	langs := make([]string, 0, len(set))
