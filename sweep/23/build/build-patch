 }
 
+// KnownLanguages returns the sorted, deduplicated list of all known language IDs
+// from certifiableExts. This is the canonical registry of languages the
+// discovery layer can recognize.
+func KnownLanguages() []string {
+	seen := make(map[string]bool)
+	for _, lang := range certifiableExts {
+		seen[lang] = true
+	}
+	langs := make([]string, 0, len(seen))
+	for lang := range seen {
+		langs = append(langs, lang)
+	}
+	sort.Strings(langs)
+	return langs
+}
