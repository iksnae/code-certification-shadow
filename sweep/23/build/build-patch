+package engine_test
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+	"github.com/iksnae/code-certification/internal/engine"
+)
+
+// TestTierRegistry_AllKnownLanguagesHaveTiers asserts that every language ID
+// returned by discovery.KnownLanguages() has a non-zero (registered) entry
+// when passed to engine.TierForLanguage.  A new extension added to the
+// discovery scanner without a corresponding tier entry will fail this test.
+func TestTierRegistry_AllKnownLanguagesHaveTiers(t *testing.T) {
+	for _, lang := range discovery.KnownLanguages() {
+		tier := engine.TierForLanguage(lang)
+		if tier == 0 { // TierNone is zero, but we treat unregistered as a problem
+			t.Errorf("language %q: no tier registered — add an entry to languageTiers in internal/engine/language_tiers.go", lang)
+		}
+	}
+}
+
+// TestTierRegistry_UnknownLanguageReturnsGeneric asserts that an obviously
+// unknown language ID falls back to TierGeneric.
+func TestTierRegistry_UnknownLanguageReturnsGeneric(t *testing.T) {
+	got := engine.TierForLanguage("nonsense-language")
+	if got != engine.TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s", "nonsense-language", got, engine.TierGeneric)
+	}
+}
+
+// TestTierRegistry_SwiftIsGeneric is a regression pin: Swift must stay at
+// TierGeneric until a dedicated Swift analyser is added.
+func TestTierRegistry_SwiftIsGeneric(t *testing.T) {
+	got := engine.TierForLanguage("swift")
+	if got != engine.TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s (regression pin)", "swift", got, engine.TierGeneric)
+	}
+}
