--- /dev/null
+++ b/internal/discovery/generic_test.go
@@ -0,0 +1,41 @@
+package discovery_test
+
+import (
+	"reflect"
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+)
+
+func TestKnownLanguages(t *testing.T) {
+	langs := discovery.KnownLanguages()
+
+	// Must be sorted
+	for i := 1; i < len(langs); i++ {
+		if langs[i-1] >= langs[i] {
+			t.Errorf("KnownLanguages() not sorted: %q >= %q at [%d]", langs[i-1], langs[i], i-1)
+		}
+	}
+
+	// Must not contain duplicates
+	seen := make(map[string]bool)
+	for _, l := range langs {
+		if seen[l] {
+			t.Errorf("KnownLanguages() duplicate: %q", l)
+		}
+		seen[l] = true
+	}
+
+	// Must return all known language IDs from certifiableExts.
+	// This test fails CI when a new extension is added without updating
+	// the expected set — forcing an explicit review of the tier registry.
+	expected := []string{
+		"c", "cpp", "cs", "elixir", "erlang", "go", "java", "js",
+		"kt", "lua", "php", "proto", "py", "r", "rb", "rs",
+		"scala", "sh", "sql", "swift", "ts", "zig",
+	}
+
+	if !reflect.DeepEqual(langs, expected) {
+		t.Errorf("KnownLanguages() mismatch.\n got:  %v\n want: %v", langs, expected)
+	}
+}
