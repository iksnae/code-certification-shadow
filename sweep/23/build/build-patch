+// Package engine contains the certification scoring and status logic.
+package engine
+
+import "fmt"
+
+// Tier represents the analysis capability level for a programming language.
+type Tier int
+
+const (
+	TierNone    Tier = iota // no analysis support
+	TierGeneric             // generic (file-type-aware) analysis only
+	TierLint                // linting support
+	TierParse               // AST/parse-tree support
+	TierFull                // full semantic analysis
+)
+
+// tierNames maps each Tier to its human-readable name.
+var tierNames = map[Tier]string{
+	TierNone:    "None",
+	TierGeneric: "Generic",
+	TierLint:    "Lint",
+	TierParse:   "Parse",
+	TierFull:    "Full",
+}
+
+// String returns the human-readable name of the tier.
+func (t Tier) String() string {
+	if name, ok := tierNames[t]; ok {
+		return name
+	}
+	return fmt.Sprintf("Tier(%d)", int(t))
+}
+
+// languageTiers maps every known language ID to its analysis capability tier.
+var languageTiers = map[string]Tier{
+	// Full semantic analysis
+	"go": TierFull,
+	"ts": TierFull,
+	"js": TierFull,
+	"py": TierFull,
+	"rs": TierFull,
+
+	// Generic file-type-aware analysis
+	"rb":     TierGeneric,
+	"java":   TierGeneric,
+	"kt":     TierGeneric,
+	"sh":     TierGeneric,
+	"c":      TierGeneric,
+
