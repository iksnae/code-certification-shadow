diff --git a/internal/discovery/generic.go b/internal/discovery/generic.go
index abcb9fa16..dd78c15c4 100644
--- a/internal/discovery/generic.go
+++ b/internal/discovery/generic.go
@@ -82,6 +82,22 @@ var scanSkipDirs = map[string]bool{
 // Backward-compatible alias
 var languageFromExt = certifiableExts
 
+// KnownLanguages returns every unique language ID from certifiableExts,
+// deduplicated and sorted. It is the single source of truth for which
+// languages the discovery layer can recognize.
+func KnownLanguages() []string {
+	seen := make(map[string]bool)
+	for _, lang := range certifiableExts {
+		seen[lang] = true
+	}
+	langs := make([]string, 0, len(seen))
+	for lang := range seen {
+		langs = append(langs, lang)
+	}
+	sort.Strings(langs)
+	return langs
+}
+
 // GenericScanner discovers all files as file-level units.
 type GenericScanner struct {
 	include []string // glob patterns to include (nil = all)
diff --git a/internal/discovery/scanner_test.go b/internal/discovery/scanner_test.go
index c3b229c66..b195d3f42 100644
--- a/internal/discovery/scanner_test.go
+++ b/internal/discovery/scanner_test.go
@@ -248,3 +248,35 @@ func TestScanners_RegistryMatchesDetectedAdapters(t *testing.T) {
 		}
 	}
 }
+
+func TestKnownLanguages(t *testing.T) {
+	langs := discovery.KnownLanguages()
+
+	if len(langs) == 0 {
+		t.Fatal("KnownLanguages() returned empty slice")
+	}
+
+	// Must be sorted and deduplicated
+	for i := 1; i < len(langs); i++ {
+		if langs[i] <= langs[i-1] {
+			t.Errorf("KnownLanguages() not sorted/deduplicated at index %d: %q <= %q", i, langs[i], langs[i-1])
+		}
+	}
+
+	// Every language known to certifiableExts must appear
+	expected := []string{
+		"c", "cpp", "cs", "elixir", "erlang", "go", "java", "js", "kt", "lua",
+		"php", "proto", "py", "r", "rb", "rs", "scala", "sh", "sql", "swift",
+		"ts", "zig",
+	}
+
+	if len(langs) != len(expected) {
+		t.Errorf("KnownLanguages() returned %d languages, want %d; got=%v", len(langs), len(expected), langs)
+	}
+
+	for i, want := range expected {
+		if i >= len(langs) || langs[i] != want {
+			t.Errorf("KnownLanguages()[%d] = %q, want %q", i, langs[i], want)
+		}
+	}
+}
