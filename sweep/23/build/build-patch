+package engine
+
+// Tier represents the analysis capability level fo
...[elided 711 bytes - full stream is hash-only]...
ability tier.
+var languageTiers = map[string]Tier{
+	// TierFull languages (deep semantic analysis)
+	"go": TierFull,
+	"ts": TierFull,
+	"js": TierFull,
+	"py": TierFull,
+	"rs": TierFull,
+
+	// TierGeneric languages (file-level classification only)
+	"rb":     TierGeneric,
+	"java":   TierGeneric,
+	"kt":     TierGeneric,
+	"sh":     TierGeneric,
+	"c":      TierGeneric,
+	"cpp":    TierGeneric,
+	"cs":     TierGeneric,
+	"swift":  TierGeneric,
+	"php":    TierGeneric,
+	"elixir": TierGeneric,
+	"erlang": TierGeneric,
+	"scala":  TierGeneric,
+	"lua":    TierGeneric,
+	"r":      TierGeneric,
+	"zig":    TierGeneric,
+	"sql":    TierGeneric,
+	"proto":  TierGeneric,
+}
+
+// TierForLanguage returns the analysis tier for the given language ID.
+// Unknown languages return TierGeneric.
+func TierForLanguage(lang string) Tier {
+	if tier, ok := languageTiers[lang]; ok {
+		return tier
+	}
+	return TierGeneric
+}
diff --git a/internal/engine/language_tiers_test.go b/internal/engine/language_tiers_test.go
new file mode 100644
index 000000000..d6bf206a3
--- /dev/null
+++ b/internal/engine/language_tiers_test.go
@@ -0,0 +1,29 @@
+package engine
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+)
+
+func TestTierRegistry_AllKnownLanguagesHaveTiers(t *testing.T) {
+	for _, lang := range discovery.KnownLanguages() {
+		tier := languageTiers[lang]
+		if tier == TierNone {
+			t.Errorf("language %q has no tier entry in the registry (tier=0 / TierNone); "+
+				"add it to languageTiers in language_tiers.go", lang)
+		}
+	}
+}
+
+func TestTierRegistry_UnknownLanguageReturnsGeneric(t *testing.T) {
+	if got := TierForLanguage("nonsense"); got != TierGeneric {
+		t.Errorf("expected TierGeneric for unknown language, got %v", got)
+	}
+}
+
+func TestTierRegistry_SwiftIsGeneric(t *testing.T) {
+	if got := TierForLanguage("swift"); got != TierGeneric {
+		t.Errorf("expected swift to be TierGeneric, got %v", got)
+	}
+}
