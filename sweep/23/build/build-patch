+// KnownLanguages returns every unique language ID from certifiableExts, deduplicated and sorted.
+func KnownLanguages() []string {
+	set := make(map[string]bool, len(certifiableExts))
+	for _, lang := range certifiableExts {
+		set[lang] = true
+	}
+	langs := make([]string, 0, len(set))
+	for lang := range set {
+		langs = append(langs, lang)
+	}
+	sort.Strings(langs)
+	return langs
+}
