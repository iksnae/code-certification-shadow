+// This fails CI when a new language extension is added to discovery without a
+// corresponding tier entry.
+func TestTierRegistry_AllKnownLanguagesHaveTiers(t *testing.T) {
+	known := discovery.KnownLanguages()
+	for _, lang := range known {
+		tier := TierForLanguage(lang)
+		if tier == 0 {
+			t.Errorf("language %q from discovery.KnownLanguages() has no tier entry (got Tier(%d))", lang, tier)
