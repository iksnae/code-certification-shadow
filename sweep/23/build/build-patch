+package engine
+
+import "fmt"
+
+// Tier represents the analysis capability tier for a programming language.
+type Tier int
+
+const (
+	TierNone    Tier = iota // 0 — language is not recognized
+	TierGeneric             // basic file metrics only (lines, size, binary detection)
+	TierLint                // linter-based evidence available
+	TierParse               // AST or parse-tree level analysis available
+	TierFull                // full semantic analysis (types, call graphs, etc.)
+)
+
+// String returns a human-readable name for the tier.
+func (t Tier) String() string {
+	if s, ok := tierNames[t]; ok {
+		return s
+	}
+	return fmt.Sprintf("Tier(%d)", t)
+}
+
+var tierNames = map[Tier]string{
+	TierNone:    "None",
+	TierGeneric: "Generic",
+	TierLint:    "Lint",
+	TierParse:   "Parse",
+	TierFull:    "Full",
+}
+
+// languageTiers maps every known language ID to its analysis capability tier.
+// When discovery gains support for a new language extension, a corresponding
+// entry MUST be added here — the test suite enforces this invariant.
+var languageTiers = map[string]Tier{
+	// Full analysis
+	"go": TierFull,
+	"ts": TierFull,
+	"js": TierFull,
+	"py": TierFull,
+	"rs": TierFull,
+
+	// Generic analysis
+	"rb":     TierGeneric,
+	"java":   TierGeneric,
+	"kt
...[elided 1924 bytes - full stream is hash-only]...
to":  TierGeneric,
+	}
+
+	if len(expected) != 22 {
+		t.Errorf("expected exactly 22 language→tier entries in the test table, got %d", len(expected))
+	}
+
+	for lang, wantTier := range expected {
+		gotTier := TierForLanguage(lang)
+		if gotTier != wantTier {
+			t.Errorf("TierForLanguage(%q) = %s, want %s", lang, gotTier, wantTier)
+		}
+	}
+
+	// Detect unknown languages: if the registry has more keys than we test for,
+	// it means a language was added to discovery without a corresponding test entry.
+	for lang := range languageTiers {
+		if _, ok := expected[lang]; !ok {
+			t.Errorf("languageTiers has key %q which is not in the test table — add it to the expected map in TestLanguageTiersRegistryHasAllKnownLanguages and assign a tier", lang)
+		}
+	}
+
+	// Detect missing keys: if we expect a language that isn't in the registry,
+	// the TierForLanguage call already failed above — but also flag the registry size.
+	if len(languageTiers) != len(expected) {
+		t.Errorf("languageTiers has %d entries, test expects %d — registry and test are out of sync", len(languageTiers), len(expected))
+	}
+}
+
+func TestTierForLanguageUnknownReturnsGeneric(t *testing.T) {
+	got := TierForLanguage("haskell")
+	if got != TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s (unknown languages should default to TierGeneric)", "haskell", got, TierGeneric)
+	}
+
+	got = TierForLanguage("")
+	if got != TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s (empty string should default to TierGeneric)", "", got, TierGeneric)
+	}
+}
+
+func TestTierString(t *testing.T) {
+	tests := []struct {
+		tier Tier
+		want string
+	}{
+		{TierNone, "None"},
+		{TierGeneric, "Generic"},
+		{TierLint, "Lint"},
+		{TierParse, "Parse"},
+		{TierFull, "Full"},
+		{Tier(99), "Tier(99)"},
+	}
+
+	for _, tt := range tests {
+		got := tt.tier.String()
+		if got != tt.want {
+			t.Errorf("Tier(%d).String() = %q, want %q", tt.tier, got, tt.want)
+		}
+	}
+}
