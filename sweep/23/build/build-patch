@@ -82,6 +82,21 @@ var scanSkipDirs = map[string]bool{
 // Backward-compatible alias
 var languageFromExt = certifiableExts
 
+// KnownLanguages returns the sorted, deduplicated set of language IDs from
+// the certifiableExts map — the single source of truth for known languages.
+func KnownLanguages() []string {
+	seen := make(map[string]bool)
+	for _, lang := range certifiableExts {
+		seen[lang] = true
+	}
+	out := make([]string, 0, len(seen))
+	for lang := range seen {
+		out = append(out, lang)
+	}
+	sort.Strings(out)
+	return out
+}
+
 // GenericScanner discovers all files as file-level units.
 type GenericScanner struct {
 	include []string // glob patterns to include (nil = all)
