diff --git a/internal/engine/language_tiers_test.go b/internal/engine/language_tiers_test.go
new file mode 100644
index 000000000..99c04c63a
--- /dev/null
+++ b/internal/engine/language_tiers_test.go
@@ -0,0 +1,39 @@
+package engine
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+)
+
+// TestTierRegistry_AllKnownLanguagesHaveTiers verifies that every language ID
+// returned by discovery.KnownLanguages() has a non-zero (non-TierNone) entry
+// in the languageTiers registry. This fails CI when a new certifiable
+// extension is added without a corresponding tier entry.
+func TestTierRegistry_AllKnownLanguagesHaveTiers(t *testing.T) {
+	known := discovery.KnownLanguages()
+	for _, lang := range known {
+		tier := TierForLanguage(lang)
+		if tier == TierNone {
+			t.Errorf("language %q has no tier entry (TierNone) — add it to languageTiers in language_tiers.go", lang)
+		}
+	}
+}
+
+// TestTierRegistry_UnknownLanguageReturnsGeneric asserts that an unrecognized
+// language ID falls back to TierGeneric, not TierNone or another tier.
+func TestTierRegistry_UnknownLanguageReturnsGeneric(t *testing.T) {
+	tier := TierForLanguage("nonsense")
+	if tier != TierGeneric {
+		t.Errorf("expected TierGeneric for unknown language, got %s (%d)", tier, tier)
+	}
+}
+
+// TestTierRegistry_SwiftIsGeneric is a regression pin: Swift currently only
+// has generic support (no deep analysis adapter).
+func TestTierRegistry_SwiftIsGeneric(t *testing.T) {
+	tier := TierForLanguage("swift")
+	if tier != TierGeneric {
+		t.Errorf("expected swift → TierGeneric, got %s (%d)", tier, tier)
+	}
+}
