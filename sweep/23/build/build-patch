--- /dev/null
+++ b/internal/discovery/generic_test.go
@@ -0,0 +1,53 @@
+package discovery_test
+
+import (
+	"sort"
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+)
+
+func TestKnownLanguages_DeduplicatedAndSorted(t *testing.T) {
+	langs := discovery.KnownLanguages()
+
+	// Must be sorted
+	if !sort.StringsAreSorted(langs) {
+		t.Errorf("KnownLanguages() is not sorted: %v", langs)
+	}
+
+	// Must have no duplicates
+	seen := make(map[string]bool)
+	for _, l := range langs {
+		if seen[l] {
+			t.Errorf("KnownLanguages() contains duplicate %q", l)
+		}
+		seen[l] = true
+	}
+
+	// Every language ID in the list must be non-empty
+	for _, l := range langs {
+		if l == "" {
+			t.Error("KnownLanguages() contains empty string")
+		}
+	}
+
+	// Spot-check a few well-known IDs that must be present
+	mustHave := []string{"c", "cpp", "cs", "go", "java", "js", "php", "proto", "py", "rb", "rs", "sh", "sql", "swift", "ts"}
+	for _, want := range mustHave {
+		found := false
+		for _, l := range langs {
+			if l == want {
+				found = true
+				break
+			}
+		}
+		if !found {
+			t.Errorf("KnownLanguages() missing %q", want)
+		}
+	}
+
+	// Verify counts: every unique value in certifiableExts appears exactly once
+	if len(langs) == 0 {
+		t.Fatal("KnownLanguages() returned empty slice")
+	}
+}
