+package engine
+
+import "testing"
+
+func TestTierForLanguage_KnownLanguages(t *testing.T) {
+	tests := []struct {
+		lang string
+		want Tier
+	}{
+		// Full semantic analysis
+		{"go", TierFull},
+		{"ts", TierFull},
+		{"js", TierFull},
+		{"py", TierFull},
+		{"rs", TierFull},
+
+		// Generic analysis
+		{"rb", TierGeneric},
+		{"java", TierGeneric},
+		{"kt", TierGeneric},
+		{"sh", TierGeneric},
+		{"c", TierGeneric},
+		{"cpp", TierGeneric},
+		{"cs", TierGeneric},
+		{"swift", TierGeneric},
+		{"php", TierGeneric},
+		{"elixir", TierGeneric},
+		{"erlang", TierGeneric},
+		{"scala", TierGeneric},
+		{"lua", TierGeneric},
+		{"r", TierGeneric},
+		{"zig", TierGeneric},
+		{"sql", TierGeneric},
+		{"proto", TierGeneric},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.lang, func(t *testing.T) {
+			got := TierForLanguage(tt.lang)
+			if got != tt.want {
+				t.Errorf("TierForLanguage(%q) = %v, want %v", tt.lang, got, tt.want)
+			}
+		})
+	}
+}
+
+func TestTierForLanguage_UnknownReturnsGeneric(t *testing.T) {
+	unknown := []string{"haskell", "dart", "nim", "", "unknownlang"}
+	for _, lang := range unknown {
+		t.Run(lang, func(t *testing.T) {
+			got := TierForLanguage(lang)
+			if got != TierGeneric {
+				t.Errorf("TierForLanguage(%q) = %v, want TierGeneric", lang, got)
+			}
+		})
+	}
+}
+
+func TestTierForLanguage_RegistrySize(t *testing.T) {
+	// Ensure the registry has exactly 22 entries.
+	// If a new language is added to discovery without a tier entry,
+	// this count must be updated — making the omission visible in code review.
+	const expected = 22
+	if len(languageTiers) != expected {
+		t.Errorf("languageTiers has %d entries, expected %d. "+
+			"Update this test AND the registry if a new language ID was added/removed.",
+			len(languageTiers), expected)
+	}
+}
