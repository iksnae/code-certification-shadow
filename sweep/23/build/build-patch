diff --git a/internal/discovery/generic_test.go b/internal/discovery/generic_test.go
new file mode 100644
index 000000000..8f14106ce
--- /dev/null
+++ b/internal/discovery/generic_test.go
@@ -0,0 +1,49 @@
+package discovery
+
+import (
+	"sort"
+	"testing"
+)
+
+func TestKnownLanguages(t *testing.T) {
+	langs := KnownLanguages()
+
+	// Must be sorted
+	if !sort.StringsAreSorted(langs) {
+		t.Errorf("KnownLanguages() is not sorted: %v", langs)
+	}
+
+	// Must be deduplicated
+	seen := make(map[string]bool)
+	for _, lang := range langs {
+		if seen[lang] {
+			t.Errorf("KnownLanguages() has duplicate: %s", lang)
+		}
+		seen[lang] = true
+	}
+
+	// Every value in certifiableExts must appear in KnownLanguages()
+	extLangs := make(map[string]bool)
+	for _, lang := range certifiableExts {
+		extLangs[lang] = true
+	}
+	for lang := range extLangs {
+		found := false
+		for _, l := range langs {
+			if l == lang {
+				found = true
+				break
+			}
+		}
+		if !found {
+			t.Errorf("KnownLanguages() missing language %q from certifiableExts", lang)
+		}
+	}
+
+	// Every language in KnownLanguages() must appear in certifiableExts
+	for _, lang := range langs {
+		if !extLangs[lang] {
+			t.Errorf("KnownLanguages() has language %q not in certifiableExts", lang)
+		}
+	}
+}
