--- /dev/null
+++ b/internal/engine/language_tiers_test.go
@@ -0,0 +1,34 @@
+package engine
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+)
+
+func TestTierRegistry_AllKnownLanguagesHaveTiers(t *testing.T) {
+	for _, lang := range discovery.KnownLanguages() {
+		tier, ok := languageTiers[lang]
+		if !ok {
+			t.Errorf("language %q known to discovery but missing from languageTiers registry", lang)
+			continue
+		}
+		if tier == TierNone {
+			t.Errorf("language %q has TierNone in languageTiers — every known language must have a non-zero tier", lang)
+		}
+	}
+}
+
+func TestTierRegistry_UnknownLanguageReturnsGeneric(t *testing.T) {
+	got := TierForLanguage("nonsense")
+	if got != TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s", "nonsense", got, TierGeneric)
+	}
+}
+
+func TestTierRegistry_SwiftIsGeneric(t *testing.T) {
+	got := TierForLanguage("swift")
+	if got != TierGeneric {
+		t.Errorf("TierForLanguage(%q) = %s, want %s", "swift", got, TierGeneric)
+	}
+}
