+// KnownLanguages returns the unique set of language IDs known to the discovery
+// system. This is the canonical list used to enforce that every language the
+// engine can discover has a tier entry in the language-tier registry.
+func KnownLanguages() []string {
+	seen := make(map[string]bool)
+	for _, lang := range extToLanguage {
+		id := lang
+		if adapter := languageToAdapter[lang]; adapter != "" {
+			id = adapter
+		}
+		seen[id] = true
+	}
+	// Also include languages that appear only in config detection.
+	for _, langs := range configToLanguages {
+		for _, lang := range langs {
+			id := lang
+			if adapter := languageToAdapter[lang]; adapter != "" {
+				id = adapter
+			}
+			seen[id] = true
+		}
+	}
+	var out []string
+	for id := range seen {
+		out = append(out, id)
+	}
+	sort.Strings(out)
+	return out
+}
