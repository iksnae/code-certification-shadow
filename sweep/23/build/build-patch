+package discovery_test
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/discovery"
+)
+
+func TestKnownLanguages_ReturnsSortedDeduplicated(t *testing.T) {
+	langs := discovery.KnownLanguages()
+	if len(langs) == 0 {
+		t.Fatal("KnownLanguages() returned empty slice")
+	}
+
+	// Verify sorted
+	for i := 1; i < len(langs); i++ {
+		if langs[i-1] >= langs[i] {
+			t.Errorf("KnownLanguages() not sorted: %q >= %q at index %d", langs[i-1], langs[i], i)
+		}
+	}
+
+	// Verify no duplicates
+	seen := make(map[string]bool)
+	for _, lang := range langs {
+		if seen[lang] {
+			t.Errorf("duplicate language %q in KnownLanguages()", lang)
+		}
+		seen[lang] = true
+	}
+
+	// Verify that every language in certifiableExts is represented.
+	// If a new extension was added without a corresponding tier entry,
+	// we can't check that here directly (tiers are elsewhere), but at
+	// minimum this test pinpoints every language ID present.
+	// The "fail CI" requirement for missing tier entries is enforced
+	// by the tier registry test in the certification package; this test
+	// ensures the language set is accessible and well-formed.
+}
+
+func TestKnownLanguages_ContainsExpectedLanguages(t *testing.T) {
+	langs := discovery.KnownLanguages()
+	set := make(map[string]bool, len(langs))
+	for _, lang := range langs {
+		set[lang] = true
+	}
+
+	expected := []string{
+		"c", "cpp", "cs", "elixir", "erlang",
+		"go", "java", "js", "kt", "lua",
+		"php", "proto", "py", "r", "rb",
+		"rs", "scala", "sh", "sql", "swift",
+		"ts", "zig",
+	}
+	for _, want := range expected {
+		if !set[want] {
+			t.Errorf("KnownLanguages() missing expected language %q", want)
+		}
+	}
+}
+
+func TestKnownLanguages_IsDeterministic(t *testing.T) {
+	a := discovery.KnownLanguages()
+	b := discovery.KnownLanguages()
+	if len(a) != len(b) {
+		t.Fatal("KnownLanguages() is not deterministic (different lengths)")
+	}
+	for i := range a {
+		if a[i] != b[i] {
+			t.Fatalf("KnownLanguages() not deterministic: %q vs %q at index %d", a[i], b[i], i)
+		}
+	}
+}
