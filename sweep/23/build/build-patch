+// KnownLanguages returns the sorted, deduplicated list of language IDs
+// from certifiableExts — the single source of truth.
+func KnownLanguages() []string {
+	set := make(map[string]bool)
+	for _, lang := range certifiableExts {
+		set[lang] = true
+	}
+	langs := make([]string, 0, len(set))
+	for lang := range set {
+		langs = append(langs, lang)
+	}
+	sort.Strings(langs)
+	return langs
