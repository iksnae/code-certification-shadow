+func TestScore_UnsupportedLanguage_ReturnsNA(t *testing.T) {
+	unit := domain.NewUnit(
+		domain.NewUnitID("swift", "main.swift", "main"),
+		domain.UnitTypeFunction,
+	)
+	ev := []domain.Evidence{
+		evidence.LintResult{Tool: "swiftlint", ErrorCount: 0}.ToEvidence(),
+	}
+
+	rec := engine.CertifyUnit(unit, nil, ev, domain.ExpiryConfig{DefaultWindowDays: 90}, time.Now())
+
+	if rec.Grade != domain.GradeNA {
+		t.Errorf("unsupported language grade = %v, want %v", rec.Grade, domain.GradeNA)
+	}
+}
+
+func TestScore_UnmeasuredComplexity_NotScored(t *testing.T) {
+	// A language that maps to TierGeneric (e.g. Swift) with Complexity=0
+	// must not receive a maintainability score of 0.95 (the old bug).
+	metrics := evidence.CodeMetrics{TotalLines: 100, CodeLines: 80, Complexity: 0}
+	ev := []domain.Evidence{metrics.ToEvidence()}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "swift")
+
+	// Swift is TierGeneric, so Score returns nil — no dimensions at all
+	if scores != nil {
+		t.Fatal("expected nil DimensionScores for unsupported language")
+	}
+
+	// Also test with a TierGeneric language that might have complexity measured
+	// (e.g. Ruby): complexity=0 should NOT produce maintainability=0.95
+	scoresRuby := engine.Score(ev, policy.EvaluationResult{Passed: true}, "ruby")
+	if scoresRuby != nil {
+		t.Fatal("expected nil DimensionScores for ruby (TierGeneric)")
+	}
+}
