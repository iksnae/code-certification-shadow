+// TestScore_SupportedLanguage_StillWorks is a smoke test that the primary happy
+// path still works after #25 refactoring. A supported language (Go) with realistic
+// evidence should return non-nil scores (not N/A) with at least one dimension
+// and a reasonable weighted average.
+func TestScore_SupportedLanguage_StillWorks(t *testing.T) {
+	ev := []domain.Evidence{
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 0}.ToEvidence(),
+		evidence.TestResult{Tool: "go test", TotalCount: 20, PassedCount: 20, Coverage: 0.85}.ToEvidence(),
+		evidence.CodeMetrics{TotalLines: 200, CodeLines: 150, Complexity: 5, TodoCount: 1}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "go")
+
+	// Supported language (Go) should NOT return nil (nil = N/A / unsupported)
+	if scores == nil {
+		t.Fatal("Score returned nil for Go; supported language should return non-nil scores (not N/A)")
+	}
+
+	// Should have at least one dimension scored
+	if len(scores) == 0 {
+		t.Error("expected at least one dimension to be scored, got empty scores")
+	}
+
+	// Weighted average should be reasonable (> 0.60 for clean evidence)
+	avg := scores.WeightedAverage(nil)
+	if avg < 0.60 {
+		t.Errorf("weighted average = %f, want >= 0.60 for clean Go evidence", avg)
+	}
+}
+
+// TestScore_DefaultsNotInjected guards against accidental re-injection of
+// hardcoded defaults. No dimension value should be exactly 0.5 (the old default)
+// or fall in the [0.49, 0.51] range.
+func TestScore_DefaultsNotInjected(t *testing.T) {
+	ev := []domain.Evidence{
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 0}.ToEvidence(),
+		evidence.TestResult{Tool: "go test", TotalCount: 10, PassedCount: 10, Coverage: 0.80}.ToEvidence(),
+		evidence.CodeMetrics{TotalLines: 100, CodeLines: 80, Complexity: 3}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "go")
+
+	if scores == nil {
+		t.Fatal("Score returned nil for Go; supported language should return non-nil scores")
+	}
+
+	for dim, val := range scores {
+		// No dimension should have the old default value of exactly 0.5
+		if val == 0.5 {
+			t.Errorf("dimension %s = 0.5 (old default); defaults should not be injected", dim)
+		}
+		// No dimension should be near the old default [0.49, 0.51]
+		if val >= 0.49 && val <= 0.51 {
+			t.Errorf("dimension %s = %f, want outside [0.49, 0.51] (near old default)", dim, val)
+		}
+	}
+}
