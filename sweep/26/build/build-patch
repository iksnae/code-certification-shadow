+func TestScore_SupportedLanguage_StillWorks(t *testing.T) {
+	// Construct realistic Go evidence: metrics, lint, test, git history.
+	ev := []domain.Evidence{
+		evidence.CodeMetrics{TotalLines: 200, CodeLines: 150, Complexity: 3}.ToEvidence(),
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 0}.ToEvidence(),
+		evidence.TestResult{Tool: "go test", TotalCount: 20, PassedCount: 20, Coverage: 0.85}.ToEvidence(),
+		evidence.GitStats{CommitCount: 30, AuthorCount: 3, AgeDays: 90}.ToEvidence(),
+	}
+
+	evalResult := policy.EvaluationResult{Passed: true}
+	scores := engine.Score(ev, evalResult, "go")
+
+	// Post-#25: supported language must NOT return nil (N/A).
+	if scores == nil {
+		t.Fatal("supported language returned nil scores (N/A)")
+	}
+	if len(scores) == 0 {
+		t.Fatal("supported language returned empty dimension scores")
+	}
+
+	// At least one dimension should be populated.
+	found := false
+	for _, v := range scores {
+		if v > 0 {
+			found = true
+			break
+		}
+	}
+	if !found {
+		t.Error("no dimension with positive score found")
+	}
+
+	// WeightedAverage should produce a meaningful value.
+	avg := scores.WeightedAverage(nil)
+	if avg <= 0 || avg > 1 {
+		t.Errorf("weighted average out of range: %f", avg)
+	}
+
+	// StatusFromScore should resolve to a valid certification status.
+	status := engine.StatusFromScore(avg, false)
+	if status != domain.StatusCertified && status != domain.StatusCertifiedWithObservations && status != domain.StatusProbationary && status != domain.StatusDecertified {
+		t.Errorf("status from score is unrecognized: %v", status)
+	}
+}
+
+func TestScore_DefaultsNotInjected(t *testing.T) {
+	ev := []domain.Evidence{
+		evidence.CodeMetrics{TotalLines: 100, CodeLines: 80, Complexity: 5}.ToEvidence(),
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 0}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "go")
+
+	if scores == nil {
+		t.Fatal("scores should not be nil for supported language")
+	}
+
+	for dim, val := range scores {
+		// Guard: no dimension should have exactly 0.5 (the old hardcoded default).
+		if val == 0.5 {
+			t.Errorf("dimension %s has value exactly 0.5 (old default injected)", dim)
+		}
+		// Guard: no dimension should fall within a tight band around 0.5.
+		if val >= 0.49 && val <= 0.51 {
+			t.Errorf("dimension %s has value %f in default band [0.49, 0.51]", dim, val)
+		}
+	}
+}
