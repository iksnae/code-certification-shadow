+func TestScore_SupportedLanguage_StillWorks(t *testing.T) {
+	// Smoke test: a realistic Go unit with clean evidence should produce
+	// dimension scores and a weighted average in a valid range.
+	ev := []domain.Evidence{
+		evidence.CodeMetrics{TotalLines: 200, CodeLines: 150, Complexity: 3}.ToEvidence(),
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 0}.ToEvidence(),
+		evidence.TestResult{Tool: "go test", TotalCount: 10, PassedCount: 10, Coverage: 0.85}.ToEvidence(),
