+func TestScore_UnsupportedLanguage_ReturnsNA(t *testing.T) {
+	// Any language not registered in language_tiers (e.g. "Swift") maps to TierGeneric.
+	// Score must return nil — no dimensions for unsupported languages.
+	ev := []domain.Evidence{
+		evidence.CodeMetrics{TotalLines: 200, CodeLines: 150, Complexity: 5}.ToEvidence(),
+		evidence.LintResult{Tool: "swiftlint", ErrorCount: 0}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "Swift")
+
+	if scores != nil {
+		t.Errorf("Score for unsupported language returned %v, want nil", scores)
+	}
+
+	// WeightedAverage on nil must return 0, not panic or fabricate.
+	avg := scores.WeightedAverage(nil)
+	if avg != 0 {
+		t.Errorf("WeightedAverage on nil scores = %f, want 0", avg)
+	}
+}
+
+func TestScore_UnmeasuredComplexity_NotScored(t *testing.T) {
+	// Complexity=0 on TierGeneric (e.g. "Ruby") must NOT produce maintainability=0.95.
+	// The old complexity<=5 branch would mistakenly score 0.95 as "excellent".
+	ev := []domain.Evidence{
+		{Kind: domain.EvidenceKindMetrics, Source: "metrics", Passed: true,
+			Metrics: map[string]float64{"complexity": 0}},
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "Ruby")
+
+	// Ruby maps to TierGeneric, so Score returns nil — no dimensions at all.
+	if scores != nil {
+		// If for any reason scores is non-nil, maintainability must NOT be 0.95.
+		if v, ok := scores[domain.DimMaintainability]; ok && v == 0.95 {
+			t.Error("unmeasured complexity on TierGeneric language must not score maintainability=0.95 (excellent)")
+		}
+	}
+
+	// Sanity: a supported language with complexity=0 still gets maintainability.
+	evGo := []domain.Evidence{
+		{Kind: domain.EvidenceKindMetrics, Source: "metrics", Passed: true,
+			Metrics: map[string]float64{"complexity": 0}},
+	}
+	scoresGo := engine.Score(evGo, policy.EvaluationResult{Passed: true}, "go")
+	if v, ok := scoresGo[domain.DimMaintainability]; !ok || v < 0.90 {
+		t.Errorf("Go (supported) complexity=0 maintainability = %v (present=%v), want present and >= 0.90", v, ok)
+	}
+}
