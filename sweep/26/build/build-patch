+// TestScore_UnsupportedLanguage_ReturnsNA verifies that Score returns nil
+// (no fabricated dimension scores) for languages not registered in the
+// analysis package (TierGeneric), e.g. Swift.
+func TestScore_UnsupportedLanguage_ReturnsNA(t *testing.T) {
+	ev := []domain.Evidence{
+		evidence.LintResult{Tool: "swiftlint", ErrorCount: 2}.ToEvidence(),
+		evidence.TestResult{Tool: "xctest", TotalCount: 10, PassedCount: 8, Coverage: 0.7}.ToEvidence(),
+		evidence.CodeMetrics{TotalLines: 200, CodeLines: 150, Complexity: 3}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "swift")
+
+	// Unsupported language must produce nil DimensionScores — no fabricated
+	// dimensions should appear.
+	if scores != nil {
+		t.Errorf("unsupported language should return nil scores, got %v with %d entries", scores, len(scores))
+	}
+
+	// Verify weighted average on nil is zero (no phantom scores).
+	avg := scores.WeightedAverage(nil)
+	if avg != 0 {
+		t.Errorf("nil scores weighted average = %f, want 0", avg)
+	}
+}
+
+// TestScore_UnmeasuredComplexity_NotScored guards the bug where zero
+// complexity was previously scored as "excellent" (0.95) for languages that
+// can't actually measure complexity (TierGeneric). With the fix, complexity=0
+// on an unsupported language must not produce a maintainability dimension
+// set to 0.95.
+func TestScore_UnmeasuredComplexity_NotScored(t *testing.T) {
+	// Evidence with complexity=0 on an unsupported language (Swift).
+	ev := []domain.Evidence{{
+		Kind:   domain.EvidenceKindMetrics,
+		Source: "metrics",
+		Passed: true,
+		Metrics: map[string]float64{
+			"complexity": 0,
+		},
+	}}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "swift")
+
+	// For TierGeneric, Score returns nil — no dimensions at all.
+	if scores != nil {
+		t.Fatalf("unsupported language should return nil scores, got %v", scores)
+	}
+
+	// Guard: maintainability must not be present (and certainly not 0.95).
+	if v, ok := scores[domain.DimMaintainability]; ok {
+		t.Errorf("maintainability should be absent for unsupported language, got %f", v)
+	}
+}
+
+// TestScore_AggregateSkipsUnsupported is a placeholder for when an aggregate
