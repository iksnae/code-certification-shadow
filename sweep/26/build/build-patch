+// TestScore_UnsupportedLanguage_ReturnsNA verifies that calling Score with an
+// unsupported language (Swift, which maps to TierGeneric) returns nil — the
+// post-#25 signal for N/A. No dimension scores are fabricated for languages
+// without registered analysis support.
+func TestScore_UnsupportedLanguage_ReturnsNA(t *testing.T) {
+	ev := []domain.Evidence{
+		evidence.CodeMetrics{TotalLines: 50, CodeLines: 40, Complexity: 3}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "Swift")
+
+	// Unsupported language must return nil (N/A)
+	if scores != nil {
+		t.Errorf("Score for unsupported language Swift returned non-nil, want nil (N/A)")
+	}
+
+	// nil DimensionScores is effectively empty — no fabricated dimension scores
+	// WeightedAverage on nil would panic, so callers must guard with nil check
+}
+
+// TestScore_UnmeasuredComplexity_NotScored guards the bug where zero complexity
+// was mis-scored as excellent (0.95 maintainability) for languages that cannot
+// measure complexity. For a TierGeneric language with Complexity=0, the
+// Score function returns nil (no dimensions at all), ensuring zero complexity
+// on an unsupported language never inflates maintainability.
+func TestScore_UnmeasuredComplexity_NotScored(t *testing.T) {
+	// Ruby is not a registered language; it maps to TierGeneric.
+	ev := []domain.Evidence{
+		evidence.CodeMetrics{TotalLines: 100, CodeLines: 80, Complexity: 0}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "Ruby")
+
+	// TierGeneric → Score returns nil immediately, so no dimensions exist.
+	// This proves zero complexity on an unmeasured language does NOT produce
+	// a maintainability score of 0.95 (or any score at all).
+	if scores != nil {
+		// If Score ever returned non-nil for TierGeneric, ensure maintainability
+		// isn't falsely set to 0.95 from the old complexity≤5 branch.
+		if v, ok := scores[domain.DimMaintainability]; ok && v == 0.95 {
+			t.Errorf("maintainability = 0.95 for unmeasured complexity on Ruby; zero complexity must not score as excellent for TierGeneric")
+		}
+	}
+}
