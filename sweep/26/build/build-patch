+	if len(scores) == 0 {
+		t.Error("DimensionScores is empty for supported language; expected at least one dimension")
+	}
+	avg := scores.WeightedAverage(nil)
+	if avg < 0.6 || avg > 1.0 {
+		t.Errorf("weighted average = %f, want in [0.6, 1.0] for clean evidence", avg)
+	}
+
+	// Verify the status derived from the score is a valid certification status
+	// (not something like N/A).
+	status := engine.StatusFromScore(avg, false)
+	switch status {
+	case domain.StatusCertified, domain.StatusCertifiedWithObservations,
+		domain.StatusProbationary, domain.StatusDecertified:
+		// all valid
+	default:
+		t.Errorf("unexpected status %v from score %f", status, avg)
+	}
+}
