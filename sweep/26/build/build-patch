+func TestScore_SupportedLanguage_StillWorks(t *testing.T) {
+	// Construct realistic Go evidence: metrics with complexity > 0, coverage, lint pass, test pass
+	ev := []domain.Evidence{
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 0}.ToEvidence(),
+		evidence.TestResult{Tool: "go test", TotalCount: 10, PassedCount: 10, Coverage: 0.85}.ToEvidence(),
+		evidence.CodeMetrics{TotalLines: 200, CodeLines: 150, Complexity: 6}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "go")
+
+	// Supported language (Go) must NOT return nil — nil is reserved for unsupported languages
+	if scores == nil {
+		t.Fatal("Score returned nil for supported language 'go' — unsupported-language guard erroneously triggered")
+	}
+
+	// Must have at least one dimension populated
+	if len(scores) == 0 {
+		t.Fatal("Score returned empty DimensionScores — expected at least one dimension from realistic Go evidence")
+	}
+
+	// Every dimension present should have a plausible score value (not N/A sentinel)
+	for dim, val := range scores {
+		if val < 0.0 || val > 1.0 {
+			t.Errorf("dimension %s has out-of-range score %f", dim, val)
+		}
+	}
+
+	// WeightedAverage should produce a meaningful result
+	avg := scores.WeightedAverage(nil)
+	if avg <= 0.0 || avg > 1.0 {
+		t.Errorf("WeightedAverage = %f, want in (0.0, 1.0]", avg)
+	}
+}
+
+func TestScore_DefaultsNotInjected(t *testing.T) {
+	// Construct evidence that triggers several dimensions but does NOT use default values
+	ev := []domain.Evidence{
+		evidence.LintResult{Tool: "golangci-lint", ErrorCount: 2}.ToEvidence(),
+		evidence.TestResult{Tool: "go test", TotalCount: 5, PassedCount: 5, Coverage: 0.72}.ToEvidence(),
+		evidence.CodeMetrics{TotalLines: 120, CodeLines: 90, Complexity: 7}.ToEvidence(),
+	}
+
+	scores := engine.Score(ev, policy.EvaluationResult{Passed: true}, "go")
+
+	if len(scores) == 0 {
+		t.Fatal("Score returned empty DimensionScores — expected dimensions from Go evidence")
+	}
+
+	// Guard against accidental re-injection of hardcoded defaults (old value was 0.5)
+	for dim, val := range scores {
+		if val == 0.5 {
+			t.Errorf("dimension %s has score exactly 0.5 (old default value) — possible re-injection of hardcoded default", dim)
+		}
+		if val > 0.49 && val < 0.51 {
+			t.Errorf("dimension %s has score %f in [0.49, 0.51] — suspiciously close to old default 0.5", dim, val)
+		}
+	}
+}
