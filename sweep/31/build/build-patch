 		t.Error("Score() violations should not introduce new dimensions when no evidence exists")
 	}
 }
+
+func TestScorer_TierGenericReturnsNil(t *testing.T) {
+	ev := []domain.Evidence{
+		{Kind: domain.EvidenceKindTest, Passed: true},
+	}
+	evalResult := policy.EvaluationResult{
+		Violations: []domain.Violation{
+			{Dimension: domain.DimCorrectness, Severity: domain.SeverityWarning},
+		},
+	}
+
+	scores := Score("swift", ev, evalResult)
+	if scores != nil {
+		t.Errorf("Score() with TierGeneric language 'swift' should return nil, got %v", scores)
+	}
+}
+
+func TestScorer_ZeroComplexityTierGenericNoMaintainabilityBoost(t *testing.T) {
+	ev := []domain.Evidence{
+		{
+			Kind:    domain.EvidenceKindMetrics,
+			Metrics: map[string]float64{"complexity": 0},
+		},
+	}
+	evalResult := policy.EvaluationResult{}
+
+	scores := Score("swift", ev, evalResult)
+	// TierGeneric with complexity=0 should return nil (entire scoring gated).
+	if scores != nil {
+		t.Errorf("Score() with TierGeneric language 'swift' should return nil, got %v", scores)
+	}
+}
+
+func TestScorer_ViolationOnAbsentDimensionDoesNotInject(t *testing.T) {
+	// Evidence sets correctness dimension but violation targets maintainability.
+	// Violation on an absent dimension should NOT inject it.
+	ev := []domain.Evidence{
+		{Kind: domain.EvidenceKindLint, Passed: true},
+	}
+	evalResult := policy.EvaluationResult{
+		Violations: []domain.Violation{
+			{Dimension: domain.DimMaintainability, Severity: domain.SeverityError},
+		},
+	}
+
+	scores := Score("go", ev, evalResult)
+	if _, ok := scores[domain.DimMaintainability]; ok {
+		t.Error("Score() violations on absent dimension should not inject that dimension")
+	}
+	// Correctness should be present (from evidence).
+	if _, ok := scores[domain.DimCorrectness]; !ok {
+		t.Error("Score() should still set dimensions that have evidence")
+	}
+}
