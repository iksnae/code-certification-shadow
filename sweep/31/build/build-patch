+// Package language_tiers classifies programming languages into tiers
+// that control which certification features apply. TierNative languages
+// enjoy full certification support; TierGeneric languages receive a
+// reduced set of checks.
+package language_tiers
+
+import "strings"
+
+// Tier represents the certification tier for a programming language.
+type Tier int
+
+const (
+	// TierGeneric is the default tier for languages without native
+	// certification support. Only universal checks apply.
+	TierGeneric Tier = 0
+
+	// TierNative is the tier for languages with full native
+	// certification support, including language-specific rules.
+	TierNative Tier = 1
+)
+
+// TierForLanguage returns the certification [Tier] for the given
+// language identifier. The match is case-insensitive. Languages with
+// native support return [TierNative]; all others return [TierGeneric].
+func TierForLanguage(lang string) Tier {
+	switch {
+	case strings.EqualFold(lang, "go"):
+		return TierNative
+	case strings.EqualFold(lang, "typescript"):
+		return TierNative
+	case strings.EqualFold(lang, "python"):
+		return TierNative
+	case strings.EqualFold(lang, "rust"):
+		return TierNative
+	default:
+		return TierGeneric
+	}
+}
