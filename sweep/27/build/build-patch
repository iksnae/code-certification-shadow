+package report
+
+import (
+	"testing"
+
+	"github.com/iksnae/code-certification/internal/domain"
+)
+
+func makePartitionRecord(lang, path, symbol string) domain.CertificationRecord {
+	return domain.CertificationRecord{
+		UnitID:   domain.NewUnitID(lang, path, symbol),
+		UnitType: domain.UnitTypeFunction,
+		UnitPath: path,
+	}
+}
+
+func TestPartitionByLanguage_AllSupported(t *testing.T) {
+	records := []domain.CertificationRecord{
+		makePartitionRecord("go", "a.go", "A"),
+		makePartitionRecord("ts", "b.ts", "B"),
+		makePartitionRecord("py", "c.py", "C"),
+	}
+
+	supported, unsupported := partitionByLanguage(records)
+
+	if len(supported) != 3 {
+		t.Errorf("supported = %d, want 3", len(supported))
+	}
+	if len(unsupported) != 0 {
+		t.Errorf("unsupported = %d, want 0", len(unsupported))
+	}
+}
+
+func TestPartitionByLanguage_UnsupportedLanguage(t *testing.T) {
+	records := []domain.CertificationRecord{
+		makePartitionRecord("go", "a.go", "A"),
+		makePartitionRecord("cpp", "b.cpp", "B"),
+		makePartitionRecord("java", "c.java", "C"),
+		makePartitionRecord("ts", "d.ts", "D"),
+	}
+
+	supported, unsupported := partitionByLanguage(records)
+
+	if len(supported) != 2 {
+		t.Errorf("supported = %d, want 2", len(supported))
+	}
+	if len(unsupported) != 2 {
+		t.Errorf("unsupported = %d, want 2", len(unsupported))
+	}
+
+	// Verify unsupported contains the expected records
+	unsupportedLangs := map[string]bool{}
+	for _, r := range unsupported {
+		unsupportedLangs[r.UnitID.Language()] = true
+	}
+	if !unsupportedLangs["cpp"] {
+		t.Error("cpp should be in unsupported")
+	}
+	if !unsupportedLangs["java"] {
+		t.Error("java should be in unsupported")
+	}
+}
+
+func TestPartitionByLanguage_Empty(t *testing.T) {
+	supported, unsupported := partitionByLanguage(nil)
+	if len(supported) != 0 || len(unsupported) != 0 {
+		t.Error("both slices should be empty for nil input")
+	}
+}
